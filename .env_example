insta_username="__________"
genai_api_key="........."

# --- Data (always outside the application repo) ---
# Path the *app* uses (container, Ubuntu server, pods). Keep this the same everywhere.
insta_news_data_root=/opt/insta_news_data
insta_news_db_path=/opt/insta_news_data/insta_news.db
INSTA_NEWS_DATA_MOUNT=/opt/insta_news_data

# Ubuntu server: host folder is the same as above.
INSTA_NEWS_DATA_ROOT=/opt/insta_news_data

# Mac + Docker Desktop: /opt is not shared by default. Use a folder under your home
# directory on the Mac, but still mount it to /opt/insta_news_data in the container:
#   mkdir -p ~/insta_news_data
#   cp /path/to/your.db ~/insta_news_data/insta_news.db
#   INSTA_NEWS_DATA_ROOT=/Users/YOU/insta_news_data
# (Or add /opt/insta_news_data under Docker → Settings → Resources → File Sharing.)

# BACKUP: Copy /opt/insta_news_data regularly (SQLite + any files there).
# Also back up FERNET_EMAIL_ENC_KEY securely — without the key, encrypted emails
# in the DB cannot be recovered and subscribers lose manage-link access.

# Amazon SES SMTP settings for magic-link emails.
# These are SES SMTP credentials from the SES console (not IAM access keys).
SMTP_USERNAME="your-ses-smtp-username"
SMTP_PASSWORD="your-ses-smtp-password"
SES_REGION="ap-southeast-2"
SES_FROM_EMAIL="verified-sender@example.com"
SES_TO_EMAIL="test-recipient@example.com"
FRONTEND_URL="https://yourdomain.com"
# Domain for Caddy HTTPS (compose.prod.yaml on droplet; no https:// prefix).
SITE_DOMAIN=yourdomain.com


# NOTE: Quotes are only needed if you have characters that the parser could misread
